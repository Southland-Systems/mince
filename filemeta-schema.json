{
  "type": "json_schema",
  "name": "filemeta-schema",
  "strict": true,
  "schema": {
    "type": "object",
    "properties": {
      "items": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "filename": {
              "type": "string"
            },
            "line_count": {
              "type": "integer"
            }
          },
          "required": ["filename", "line_count"],
          "additionalProperties": false
        }
      }
    },
    "required": ["items"],
    "additionalProperties": false
  }
}

