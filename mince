    "openai_base_url": "https://api.openai.com/v1",
    "openai_organization": "",
    "openai_project": "",
    "openai_service_tier": "auto",
    "system_prompt": (
        "You are a concise and technically accurate software engineering assistant. Output in formatted plain text unless instructed otherwise."
    ),
    "temperature": 1.0,
    "top_p": 1.0,
    "openai_reasoning": "high",
