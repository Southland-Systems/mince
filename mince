The provided files are prefixed with line numbers (example: '1 ').
Do not include the line numbers when responding or completing a task.
"""


# -------------------------------------------------------------------
# Config
# -------------------------------------------------------------------

def merged_config() -> dict[str, Any]:
    config = DEFAULT_CONFIG.copy()

    if CONFIG_FILE.exists():
        try:
            raw = json.loads(CONFIG_FILE.read_text(encoding="utf-8"))
            if isinstance(raw, dict):
                config.update(raw)
        except Exception:
            print(f"ERROR: Failed to parse config: {CONFIG_FILE}", file=sys.stderr)
            raise SystemExit(1)

    return config


def ensure_config_exists() -> None:
    APP_DIR.mkdir(parents=True, exist_ok=True)

    if not CONFIG_FILE.exists():
        save_config(DEFAULT_CONFIG.copy())


def load_config() -> dict[str, Any]:
    ensure_config_exists()
    return merged_config()


def save_config(config: dict[str, Any]) -> None:
    merged = DEFAULT_CONFIG.copy()
    merged.update(config)

    CONFIG_FILE.write_text(
        json.dumps(merged, indent=2, ensure_ascii=False),
        encoding="utf-8",
    )


def prompt_config_value(
    config: dict[str, Any],
    key: str,
    label: str,
    cast: type | None = None,
) -> None:
    current = config.get(key)
    value = input(f"{label} [{current}]: ").strip()

    if not value:
        return

    try:
        config[key] = cast(value) if cast else value
    except Exception:
        print(f"WARNING: Invalid value for {key}; keeping existing value.")


def init_config_interactive() -> None:
    ensure_config_exists()
    config = load_config()

    print(f"Config file: {CONFIG_FILE}")
    print()

    prompt_config_value(config, "model", "Model")
    prompt_config_value(config, "api_key", "API key (default OPENAI_API_KEY)")
    prompt_config_value(config, "openai_base_url", "OpenAI-compatible Base URL")
    prompt_config_value(config, "openai_organization", "Organization name or ID")
    prompt_config_value(config, "openai_project", "Project name or ID")
    prompt_config_value(config, "openai_service_tier", "Service tier")
    prompt_config_value(config, "system_prompt", "System prompt")
    prompt_config_value(config, "temperature", "Temperature (0.0-2.0)", float)
    prompt_config_value(config, "top_p", "Top P (0.0-1.0)", float)
    prompt_config_value(config, "openai_reasoning", "Reasoning (none, minimal, low, medium, high, xhigh)")
    prompt_config_value(config, "token_limit", "Input token limit", int)
    prompt_config_value(config, "max_output_tokens", "Max output tokens", int)
    prompt_config_value(config, "max_file_size_kb", "Max file size KB", int)
    prompt_config_value(config, "llm_timeout", "API timeout in seconds", int)

    save_config(config)

    print()
    print(f"Configuration saved.")


# -------------------------------------------------------------------
# Helpers
# -------------------------------------------------------------------

def number_lines(text: str) -> str:
    lines = text.splitlines()
    if not lines:
        return ""

    width = len(str(len(lines)))
    return "\n".join(f"{i} {line}" for i, line in enumerate(lines, start=1))


def estimate_request_tokens(model: str, system_prompt: str, user_prompt: str) -> int:
    try:
        encoding = tiktoken.encoding_for_model(model)
    except Exception:
        encoding = tiktoken.get_encoding("o200k_base")

    request_text = f"SYSTEM:\n{system_prompt}\n\nUSER:\n{user_prompt}"
    return len(encoding.encode(request_text))


def usage_to_dict(usage: Any) -> dict[str, Any] | None:
    if usage is None:
        return None
    if isinstance(usage, dict):
        return usage
    if hasattr(usage, "model_dump"):
        return usage.model_dump()
    if hasattr(usage, "dict"):
        return usage.dict()
    return {"raw": str(usage)}


def print_stats(
    *,
    request_characters: int,
    request_tokens: int,
    response_text: str,
    usage: dict[str, Any] | None = None,
) -> None:
    stats: list[str] = [
        f"request_characters={request_characters}",
        f"request_tokens_estimate={request_tokens}",
        f"response_characters={len(response_text)}",
    ]

    if usage:
        for key in ("input_tokens", "output_tokens", "total_tokens"):
            if key in usage:
                stats.append(f"llm_{key}={usage[key]}")

    print("stats: " + " ".join(stats), file=sys.stderr)


def coerce_int(value: Any, default: int) -> int:
    try:
        return int(value)
    except (TypeError, ValueError):
        return default


def read_file(path: Path) -> str:
    try:
        return path.read_text(encoding="utf-8")
    except UnicodeDecodeError:
        return path.read_bytes().decode("utf-8", errors="replace")
    except Exception as exc:
        return f"ERROR: cannot read file {path} ({exc})"


def build_context(
    file_paths: list[Path],
    max_file_size_kb: int,
) -> str:
    sections = []
    max_bytes = max_file_size_kb * 1024

    for path in file_paths:
        if not path.exists():
            sections.append(f"[MISSING FILE: {path}]")
            continue

        if path.stat().st_size > max_bytes:
            sections.append(
                f"[SKIPPED LARGE FILE: {path} ({path.stat().st_size} bytes)]"
            )
            continue

        content = read_file(path)
        numbered_content = number_lines(content)

        sections.append(
            f"""
---
- lines_numbered: True
- path: {path}
---
{numbered_content}
""".strip()
        )

    return "\n\n".join(sections)


def load_json_schema(path: Path) -> dict[str, Any]:
    try:
        raw = json.loads(path.read_text(encoding="utf-8"))
        if not isinstance(raw, dict):
            raise ValueError("Schema file must contain a JSON object")
        return raw
    except Exception as exc:
        print(f"ERROR: Failed to load JSON schema: {path}\n{exc}", file=sys.stderr)
        raise SystemExit(1)


def pretty_json(raw: str) -> str:
    try:
        return json.dumps(json.loads(raw), indent=2, ensure_ascii=False)
    except Exception:
        return raw


# -------------------------------------------------------------------
# Prompting
# -------------------------------------------------------------------

def build_user_prompt(
    task: str,
    context: str,
    response_format: str = "text",
    json_schema: dict[str, Any] | None = None,
) -> str:
    schema_block = ""

    if response_format == "schema" and json_schema is not None:
        schema_block = (
            "\n\nReturn ONLY valid JSON that matches this schema exactly:\n"
            f"{json.dumps(json_schema, indent=2, ensure_ascii=False)}"
        )

    return f"""
TASK:
{task}

PROJECT CONTEXT:
{context}
{schema_block}
""".strip()


# -------------------------------------------------------------------
# OpenAI-compatible request
# -------------------------------------------------------------------

def _handle_openai_error(exc: Exception) -> None:
    if isinstance(exc, AuthenticationError):
        msg = "Authentication failed – check your API key."
        code = 2
    elif isinstance(exc, RateLimitError):
        msg = "Rate limit exceeded – try again later."
        code = 3
    elif isinstance(exc, BadRequestError):
        msg = f"Bad request: {exc.user_message or exc}"
        code = 4
    elif isinstance(exc, PermissionDeniedError):
        msg = f"Permission denied: {exc.user_message or exc}"
        code = 5
    elif isinstance(exc, NotFoundError):
        msg = f"Resource not found: {exc.user_message or exc}"
        code = 6
    elif isinstance(exc, APITimeoutError):
        msg = f"Request timed out after {exc.timeout or 'unknown'} seconds."
        code = 7
    elif isinstance(exc, APIConnectionError):
        msg = f"Network error: {exc}"
        code = 8
    elif isinstance(exc, APIError):
        msg = f"OpenAI API error: {exc.user_message or exc}"
        code = 9
    elif isinstance(exc, UnprocessableEntityError):
        msg = f"Cannot process request despite it being correct: {exc.user_message or exc}"
        code = 10
    elif isinstance(exc, InternalServerError):
        msg = f"OpenAI API internal server error: {exc.user_message or exc}"
        code = 11
    else:
        msg = f"Unexpected error: {exc}"
        code = 1

    print(f"ERROR: {msg}", file=sys.stderr)
    raise SystemExit(code)

def resolve_api_key(config: dict[str, Any]) -> str:
    env_key = os.getenv("OPENAI_API_KEY")
    if env_key:
        return env_key
    key = str(config.get("api_key", "")).strip()
    if key:
        return key
    raise SystemExit("No API key found. Set it in the config file or 'export OPENAI_API_KEY=key'.")

def validate_model(model: str, client: OpenAI) -> None:
    try:
        client.models.retrieve(model)
    except:
        raise SystemExit(f"Model '{model}' does not exist or you do not have access.")

def call_openai(
    api_key: str = "",
    openai_base_url: str = "",
    openai_organization: str = "",
    openai_project: str = "",
    model: str = "",
    system_prompt: str = "",
    user_prompt: str = "",
    response_format: str = "text",
    json_schema: dict[str, Any] | None = None,
    temperature: float | None = None,
    top_p: float | None = None,
    max_output_tokens: int | None = None,
    openai_service_tier: str | None = None,
    openai_reasoning: str | None = None,
    llm_timeout: int | None = None,
) -> tuple[Any, dict[str, Any] | None]:
    client = OpenAI(
        api_key=api_key,
        base_url=openai_base_url,
        project=openai_project or None,
        organization=openai_organization or None,
        timeout=llm_timeout if llm_timeout is not None else 300,
        max_retries=2,
    )

#    validate_model(model, client)

    kwargs: dict[str, Any] = {
        "model": model,
        "instructions": system_prompt,
        "input": user_prompt,
        "extra_body": {},
    }

    if temperature is not None:
        kwargs["temperature"] = temperature

    if top_p is not None:
        kwargs["top_p"] = top_p

    if openai_reasoning is not None:
        kwargs["reasoning"] = {"effort": openai_reasoning, "summary": "detailed"}

    if max_output_tokens is not None:
        kwargs["max_output_tokens"] = max_output_tokens

    if openai_service_tier:
        kwargs["service_tier"] = openai_service_tier

    if response_format == "json":
        kwargs["text"] = {"format": {"type": "json_object"}}
    elif response_format == "schema":
        if not json_schema:
            raise ValueError("--response-format schema requires --schema-file")

        kwargs["text"] = {
            "format": {
                "type": "json_schema",
                "name": "single_shot_output",
                "schema": json_schema,
                "strict": True,
            }
        }

    try:
        response = client.responses.create(**kwargs)
    except Exception as exc:
        _handle_openai_error(exc)

    return response, usage_to_dict(getattr(response, "usage", None))


def call_llm(
    api_key: str = "",
    openai_base_url: str = "",
    openai_organization: str = "",
    openai_project: str = "",
    model: str = "",
    system_prompt: str = "",
    user_prompt: str = "",
    response_format: str = "text",
    json_schema: dict[str, Any] | None = None,
    temperature: float | None = None,
    top_p: float | None = None,
    max_output_tokens: int | None = None,
    openai_service_tier: str | None = None,
    openai_reasoning: str | None = None,
    llm_timeout: int | None = None,
) -> tuple[Any, dict[str, Any] | None]:
    return call_openai(
        api_key=api_key,
        openai_base_url=openai_base_url,
        openai_organization=openai_organization,
        openai_project=openai_project,
        model=model,
        system_prompt=system_prompt,
        user_prompt=user_prompt,
        response_format=response_format,
        json_schema=json_schema,
        temperature=temperature,
        top_p=top_p,
        max_output_tokens=max_output_tokens,
        openai_service_tier=openai_service_tier,
        openai_reasoning=openai_reasoning,
        llm_timeout=llm_timeout,
   )


# -------------------------------------------------------------------
# CLI
# -------------------------------------------------------------------

def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description="MinCE: read-only one-shot AI assistant for text files"
    )

    parser.add_argument("--task", help="Task/prompt for the model (required)")

    parser.add_argument(
        "--files",
        nargs="+",
        help="Files to include as context (required)",
    )

    parser.add_argument(
        "--init",
        action="store_true",
        help="Initialize and interactively change the configuration file",
    )


    parser.add_argument(
        "--system-prompt",
        help="System prompt override",
    )

    parser.add_argument(
        "--model",
        help="Override configured model",
    )

    parser.add_argument(
        "--openai-base-url",
        help="OpenAI-compatible API base URL",
    )

    parser.add_argument(
        "--openai-organization",
        help="Optional OpenAI organization ID",
    )

    parser.add_argument(
        "--openai-project",
        help="Optional project name or ID",
    )

    parser.add_argument(
        "--openai-service-tier",
        choices=("auto", "default", "flex", "scale", "priority"),
        help="OpenAI service tier",
    )

    parser.add_argument(
        "--response-format",
        choices=("text", "json", "schema"),
        default="text",
        help="text = normal output, json = valid JSON, schema = structured JSON Schema",
    )

    parser.add_argument(
        "--schema-file",
        type=Path,
        help="Path to a JSON Schema file (required for --response-format schema)",
    )

    parser.add_argument(
        "--temperature",
        type=float,
        help="Sampling temperature (0.0-2.0)",
    )

    parser.add_argument(
        "--top-p",
        type=float,
        help="Top-p nucleus sampling (0.0-1.0)",
    )

    parser.add_argument(
        "--openai-reasoning",
        choices=("none", "minimal", "low", "medium", "high", "xhigh"),
        help="Reasoning effort level",
    )

    parser.add_argument(
        "--token-limit",
        type=int,
        help="Maximum allowed input token count (default 65534)",
    )

    parser.add_argument(
        "--max-output-tokens",
        type=int,
        help="Maximum output tokens the LLM will use",
    )

    parser.add_argument(
        "--llm-timeout",
        type=int,
        help="Timeout in seconds for API calls (default 300)",
    )

    parser.add_argument(
        "--print-reasoning",
        action="store_true",
        help="Output the reasoning dialog in <reasoning> tags with the content in <response> tags"
    )
    parser.add_argument(
        "--quiet",
        action="store_true",
        help="Suppress printing of extra output (stats, information)",
    )

    return parser.parse_args()


# -------------------------------------------------------------------
# Main
# -------------------------------------------------------------------

def main() -> int:
    args = parse_args()

    if args.init:
        init_config_interactive()
        return 0

    if not args.task:
        print("ERROR: --help or --task and --files are required", file=sys.stderr)
        return 1

    if not args.files:
        print("ERROR: --files is required", file=sys.stderr)
        return 1

    config = load_config()

    model = str(args.model or config.get("model")).strip()
    openai_base_url = str(args.openai_base_url or config.get("openai_base_url")).strip()
    openai_organization = str(args.openai_organization or config.get("openai_organization", "")).strip()
    openai_project = str(args.openai_project or config.get("openai_project")).strip()
    system_prompt = str(args.system_prompt or config.get("system_prompt")).strip()

    temperature = (
        args.temperature
        if args.temperature is not None
        else config.get("temperature", 1.0)
    )

    top_p = args.top_p if args.top_p is not None else config.get("top_p", 1.0)

    token_limit = (
        args.token_limit
        if args.token_limit is not None
        else config.get("token_limit", 65534)
    )

    max_output_tokens = (
        args.max_output_tokens
        if args.max_output_tokens is not None
        else config.get("max_output_tokens", 65534)
    )

    openai_reasoning = (
        args.openai_reasoning
        if args.openai_reasoning is not None
        else config.get("openai_reasoning", "minimal")
    )

    llm_timeout = (
        args.llm_timeout
        if args.llm_timeout is not None
        else config.get("llm_timeout", 300)
    )

    openai_service_tier = str(args.openai_service_tier or config.get("openai_service_tier", "auto")).strip()
    response_format: str = args.response_format or str(config.get("response_format", "text"))

    json_schema: dict[str, Any] | None = None
    if response_format == "schema":
        if not args.schema_file:
            print(
                "ERROR: --schema-file is required when --response-format schema",
                file=sys.stderr,
            )
            return 1
        json_schema = load_json_schema(args.schema_file)
    elif args.schema_file:
        print(
            "ERROR: --schema-file only applies to --response-format schema",
            file=sys.stderr,
        )
        return 1

    api_key = resolve_api_key(config)
    if not api_key:
        print(f"ERROR: api_key missing in {CONFIG_FILE} or OPENAI_API_KEY", file=sys.stderr)
        print()
        print("Run:")
        print("  mince --init")
        return 1

    max_file_size_kb = coerce_int(config.get("max_file_size_kb", 512), 512)
    file_paths = [Path(f).resolve() for f in args.files]

    context = build_context(file_paths=file_paths, max_file_size_kb=max_file_size_kb)

    full_system_prompt = DEFAULT_SYSTEM_PROMPT + system_prompt

    user_prompt = build_user_prompt(
        task=args.task,
        context=context,
        response_format=response_format,
        json_schema=json_schema,
    )

    request_tokens = estimate_request_tokens(
        model=model,
        system_prompt=full_system_prompt,
        user_prompt=user_prompt,
    )

    if request_tokens > token_limit:
        print(f"ERROR: Estimated input token count ({request_tokens}) exceeds token limit ({token_limit})", file=sys.stderr)
        return 1

    request_characters = len(full_system_prompt + user_prompt)

    if not args.quiet:
        print(f"info: request_characters={request_characters} request_tokens_estimate={request_tokens}", file=sys.stderr)

    try:
        response_obj, usage = call_llm(
            api_key=api_key,
            openai_base_url=openai_base_url,
            openai_organization=openai_organization,
            openai_project=openai_project,
            model=model,
            system_prompt=full_system_prompt,
            user_prompt=user_prompt,
            response_format=response_format,
            json_schema=json_schema,
            temperature=temperature,
            top_p=top_p,
            max_output_tokens=max_output_tokens,
            openai_service_tier=openai_service_tier,
            openai_reasoning=openai_reasoning,
            llm_timeout=llm_timeout,
        )
    except Exception as exc:
        print(f"OpenAI API error: {exc}", file=sys.stderr)
        return 1

    result = getattr(response_obj, "output_text", "")

    if response_format in ("json", "schema"):
        result = pretty_json(result)

    if args.print_reasoning:
        for item in getattr(response_obj, "output", []):
            if getattr(item, "type", None) == "reasoning":
                for content in getattr(item, "content", []):
                    if getattr(content, "type", None) == "reasoning_text":
                        reasoning = getattr(content, "text", "")
        print(f"<reasoning>\n{reasoning}\n</reasoning>")
        print(f"<response>\n{result}\n</response>")
    else:
        print(result)

    if not args.quiet:
        print_stats(
            request_characters=request_characters,
            request_tokens=request_tokens,
            response_text=result,
            usage=usage,
        )
# TODO debugging response
#    print(json.dumps(response_obj.model_dump(), indent=2))

    return 0


if __name__ == "__main__":
    raise SystemExit(main())
