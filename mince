def build_user_prompt(
    task: str,
    context: str,
    response_format: str = "text",
    json_schema: dict[str, Any] | None = None,
) -> str:
    schema_block = ""

    if response_format == "schema" and json_schema is not None:
        schema_block = (
            "<json_schema instructions='Return JSON that matches this schema exactly'>\n"
            f"{json.dumps(json_schema, indent=2, ensure_ascii=False)}\n"
            "</json_schema>\n"
        )

    return f"""
<task>
{task}
</task>
<files current_working_directory='{os.getcwd()}'>
{context}
</files>
{schema_block}
""".strip()


