def _handle_openai_error(exc: Exception) -> None:
    if isinstance(exc, AuthenticationError):
        msg = "Authentication failed – check your API key."
        code = 2
    elif isinstance(exc, RateLimitError):
        msg = "Rate limit exceeded – try again later."
        code = 3
    elif isinstance(exc, BadRequestError):
        msg = f"Bad request: {exc}"
        code = 4
    elif isinstance(exc, PermissionDeniedError):
        msg = f"Permission denied: {exc}"
        code = 5
    elif isinstance(exc, NotFoundError):
        msg = f"Resource not found: {exc}"
        code = 6
    elif isinstance(exc, APITimeoutError):
        msg = f"Request timed out: {exc}"
        code = 7
    elif isinstance(exc, APIConnectionError):
        msg = f"Network error: {exc}"
        code = 8
    elif isinstance(exc, APIError):
        msg = f"OpenAI API error: {exc}"
        code = 9
    elif isinstance(exc, UnprocessableEntityError):
        msg = f"Cannot process request despite it being correct: {exc}"
        code = 10
    elif isinstance(exc, InternalServerError):
        msg = f"OpenAI API internal server error: {exc}"
        code = 11
    else:
        msg = f"Unexpected error: {exc}"
        code = 1

    print(f"ERROR: {msg}", file=sys.stderr)
    raise SystemExit(code)


def resolve_api_key(config: dict[str, Any]) -> str:
    env_key = os.getenv("OPENAI_API_KEY")
    if env_key:
        return env_key
    key = str(config.get("api_key", "")).strip()
    if key:
        return key
    raise SystemExit("No API key found. Set it in the config file or 'export OPENAI_API_KEY=key'.")


def call_openai(
    api_key: str = "",
    openai_base_url: str = "",
    openai_proxy: str = "",
    openai_organization: str = "",
    openai_project: str = "",
    model: str = "",
    system_prompt: str = "",
    user_prompt: str = "",
    response_format: str = "text",
    json_schema: dict[str, Any] | None = None,
    response_verbosity: str | None = None,
    temperature: float | None = None,
    top_p: float | None = None,
    max_output_tokens: int | None = None,
    openai_service_tier: str | None = None,
    openai_reasoning: str | None = None,
    reasoning_mode: str | None = None,
    extra_body: dict[str, Any] | None = None,
    llm_timeout: int | None = None,
    safety_identifier: str | None = None,
    store: bool = True,
    stream: bool = False,
) -> tuple[Any, dict[str, Any] | None]:
    http_client = None
    if openai_proxy:
        http_client = httpx.Client(proxy=openai_proxy)

    client = OpenAI(
        api_key=api_key,
        base_url=openai_base_url,
        project=openai_project or None,
        organization=openai_organization or None,
        timeout=llm_timeout if llm_timeout is not None else 300,
        max_retries=0,
        http_client=http_client,
    )

    kwargs: dict[str, Any] = {
        "model": model,
        "instructions": system_prompt,
        "input": user_prompt,
        "extra_body": extra_body or {},
        "store": store,
    }

    if safety_identifier is not None and str(safety_identifier).strip():
        kwargs["safety_identifier"] = str(safety_identifier).strip()

    if temperature is not None:
        kwargs["temperature"] = temperature

    if top_p is not None:
        kwargs["top_p"] = top_p

    if openai_reasoning is not None:
        reasoning_payload: dict[str, Any] = {
            "effort": openai_reasoning,
            "summary": "detailed",
        }
        if reasoning_mode is not None:
            reasoning_payload["mode"] = reasoning_mode
        kwargs["reasoning"] = reasoning_payload

    if max_output_tokens is not None:
        kwargs["max_output_tokens"] = max_output_tokens

    if openai_service_tier and str(openai_service_tier).lower() != "off":
        kwargs["service_tier"] = openai_service_tier

    if response_format == "json":
        kwargs["text"] = {"format": {"type": "json_object"}}
    elif response_format == "schema":
        if not json_schema:
            raise ValueError("--response-format schema requires --schema-file")
        kwargs["text"] = {"format": json_schema}
    else:
        text_payload: dict[str, Any] = {"format": {"type": "text"}}
        if response_verbosity and response_verbosity != "off":
            text_payload["verbosity"] = response_verbosity
        kwargs["text"] = text_payload

    if stream and response_format != "text":
        raise ValueError("Streaming is only supported for text responses")
    if stream:
        kwargs["stream"] = True

    if DEBUG:
        print("<debug_request>", file=sys.stderr)
        print(json.dumps(kwargs, indent=2), file=sys.stderr)
        print("</debug_request>", file=sys.stderr)

    try:
        response = client.responses.create(**kwargs)
    except Exception as exc:
        _handle_openai_error(exc)

    return response, usage_to_dict(getattr(response, "usage", None))

def consume_response_stream(
    stream: Any,
    emit: Any = None,
) -> tuple[str, dict[str, Any] | None, Any]:
    chunks: list[str] = []
    usage: dict[str, Any] | None = None
    completed_response = None

    for event in stream:
        event_type = getattr(event, "type", "")
        if event_type == "response.output_text.delta":
            delta = getattr(event, "delta", "")
            if delta:
                chunks.append(delta)
                if emit is not None:
                    emit(delta)
        elif event_type == "response.completed":
            completed_response = getattr(event, "response", None)
            usage = usage_to_dict(
                getattr(completed_response, "usage", None)
            )

    return "".join(chunks), usage, completed_response


