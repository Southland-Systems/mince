def number_lines(text: str) -> str:
    lines = text.splitlines()
    if not lines:
        return ""

    width = len(str(len(lines)))
    return "\n".join(f"{i} {line}" for i, line in enumerate(lines, start=1))


def estimate_request_tokens(model: str, system_prompt: str, user_prompt: str) -> int:
    try:
        encoding = tiktoken.encoding_for_model(model)
    except Exception:
        encoding = tiktoken.get_encoding("o200k_base")

    request_text = f"SYSTEM:\n{system_prompt}\n\nUSER:\n{user_prompt}"
    return len(encoding.encode(request_text))

def parse_token_cost(value: Any) -> tuple[float, float] | None:
    raw = str(value).strip()
    if raw.lower() == "off":
        return None
    parts = raw.split(":")
    if len(parts) != 2:
        raise ValueError("expected input_float:output_float or 'off' (ex: 0.55:1.55)")
    try:
        input_cost = float(parts[0].strip())
        output_cost = float(parts[1].strip())
    except ValueError as exc:
        raise ValueError("expected input_float:output_float or 'off' (ex: 0.55:1.55)") from exc
    if not all(math.isfinite(cost) and cost >= 0 for cost in (input_cost, output_cost)):
        raise ValueError("token costs must be finite non-negative floats")
    return input_cost, output_cost

def response_cost_line(
    token_cost: tuple[float, float] | None,
    usage: dict[str, Any] | None,
 ) -> str | None:
    if token_cost is None or not usage:
        return None
    try:
        input_tokens = int(usage["input_tokens"])
        output_tokens = int(usage["output_tokens"])
    except (KeyError, TypeError, ValueError):
        return None

    input_cost = input_tokens * token_cost[0] / 1_000_000
    output_cost = output_tokens * token_cost[1] / 1_000_000
    total_cost = input_cost + output_cost
    return f"response_cost={input_cost:.4f}:{output_cost:.4f}:{total_cost:.4f}"

def usage_to_dict(usage: Any) -> dict[str, Any] | None:
    if usage is None:
        return None
    if isinstance(usage, dict):
        return usage
    if hasattr(usage, "model_dump"):
        return usage.model_dump()
    if hasattr(usage, "dict"):
        return usage.dict()
    return {"raw": str(usage)}


def print_stats(
    *,
    request_characters: int,
    request_tokens: int,
    processing_time: float | None = None,
    response_text: str,
    usage: dict[str, Any] | None = None,
    response_cost: str | None = None,
 ) -> str:
    stats: list[str] = [
        f"processing_time={int(processing_time)}s",
        f"request_characters={request_characters}",
        f"request_tokens_estimate={request_tokens}",
        f"response_characters={len(response_text)}",
    ]
    if usage:
        for key in ("input_tokens", "output_tokens", "total_tokens"):
            if key in usage:
                stats.append(f"response_{key}={usage[key]}")
    if response_cost is not None:
        stats.append(response_cost)
    return " ".join(stats)


def coerce_bool(value: Any, default: bool = False) -> bool:
    if isinstance(value, bool):
        return value
    if isinstance(value, str):
        normalized = value.strip().lower()
        if normalized in ("on", "true", "yes", "1"):
            return True
        if normalized in ("off", "false", "no", "0"):
            return False
    return default

def parse_bool(value: str) -> bool:
    normalized = value.strip().lower()
    if normalized in ("on", "true", "yes", "1"):
        return True
    if normalized in ("off", "false", "no", "0"):
        return False
    raise argparse.ArgumentTypeError("expected a boolean value (true/false)")

def coerce_int(value: Any, default: int) -> int:
    try:
        return int(value)
    except (TypeError, ValueError):
        return default

def read_file(path: Path) -> str:
    try:
        return path.read_text(encoding="utf-8")
    except UnicodeDecodeError:
        return path.read_bytes().decode("utf-8", errors="replace")
    except Exception as exc:
        return f"ERROR: cannot read file {path} ({exc})"


def read_prompt_argument(value: str) -> str:
    if value == "-":
        return sys.stdin.read().strip()
    return value.strip()


def read_files_list(path: Path) -> list[str]:
    try:
        lines = path.read_text(encoding="utf-8").splitlines()
    except Exception as exc:
        raise ValueError(f"cannot read files list {path} ({exc})") from exc

    files: list[str] = []
    for raw_line in lines:
        line = raw_line.strip()
        if not line or line.startswith("#"):
            continue
        files.append(line)
    return files

def build_context(
    file_paths: list[Path],
    max_file_size_kb: int,
    add_line_numbers: bool = True,
) -> str:
    sections = []
    max_bytes = max_file_size_kb * 1024

    for path in file_paths:
        if not path.exists():
            sections.append(f"[MISSING FILE: {path}]")
            continue

        if path.stat().st_size > max_bytes:
            sections.append(
                f"[SKIPPED LARGE FILE: {path} ({path.stat().st_size} bytes)]"
            )
            continue

        content = read_file(path)
        if add_line_numbers:
            numbered_content = number_lines(content)
        else:
            numbered_content = content

        sections.append(
            f"<file path='{path}' encoding='utf-8'>\n{numbered_content}\n</file>".strip()
        )

    return "\n".join(sections)


def load_json_schema(path: Path) -> dict[str, Any]:
    try:
        raw = json.loads(path.read_text(encoding="utf-8"))
        if not isinstance(raw, dict):
            raise ValueError("Schema file must contain a JSON object")
        return raw
    except Exception as exc:
        print(f"ERROR: Failed to load JSON schema: {path}\n{exc}", file=sys.stderr)
        raise SystemExit(1)


def pretty_json(raw: str) -> str:
    try:
        return json.dumps(json.loads(raw), indent=2, ensure_ascii=False)
    except Exception:
        return raw


def parse_extra_body(s: str) -> dict[str, Any]:
    result: dict[str, Any] = {}
    if not s:
        return result
    for pair in s.split(","):
        if not pair:
            continue
        if "=" not in pair:
            continue
        key, value = pair.split("=", 1)
        key = key.strip()
        value = value.strip()
        low = value.lower()
        if low == "true":
            result[key] = True
        elif low == "false":
            result[key] = False
        else:
            try:
                result[key] = int(value)
            except ValueError:
                try:
                    result[key] = float(value)
                except ValueError:
                    result[key] = value
    return result


