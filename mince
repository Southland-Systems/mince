def merged_config() -> dict[str, Any]:
    config = DEFAULT_CONFIG.copy()

    if CONFIG_FILE.exists():
        try:
            raw = json.loads(CONFIG_FILE.read_text(encoding="utf-8"))
            if isinstance(raw, dict):
                config.update(raw)
        except Exception:
            print(f"ERROR: Failed to parse config: {CONFIG_FILE}", file=sys.stderr)
            raise SystemExit(1)

    return config


def ensure_config_exists() -> None:
    APP_DIR.mkdir(parents=True, exist_ok=True)

    if not CONFIG_FILE.exists():
        save_config(DEFAULT_CONFIG.copy())


def load_config() -> dict[str, Any]:
    ensure_config_exists()
    return merged_config()


def save_config(config: dict[str, Any]) -> None:
    merged = DEFAULT_CONFIG.copy()
    merged.update(config)

    CONFIG_FILE.write_text(
        json.dumps(merged, indent=2, ensure_ascii=False),
        encoding="utf-8",
    )

def prompt_config_value(
    config: dict[str, Any],
    key: str,
    label: str,
    cast: type | None = None,
    mask: bool = False,
) -> None:
    current = config.get(key)

    if mask and isinstance(current, str) and current:
        if len(current) > 8:
            # Show first 4, asterisks for the middle, last 4.
            masked = f"{current[:4]}{'*' * (len(current) - 8)}{current[-4:]}"
        else:
            # Very short keys – just hide everything.
            masked = "*" * len(current)
    else:
        masked = current
    value = input(f"{label} [{masked}]: ").strip()

    if not value:
        return

    try:
        config[key] = cast(value) if cast else value
    except Exception:
        print(f"WARNING: Invalid value for {key}; keeping existing value.")


