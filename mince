def main() -> int:
    tokenizer_padding = 0

    json_schema = None
    reasoning = ""

    global CONFIG_FILE
    global VERBOSE
    global DEBUG

    args = parse_args()

    if args.quiet:
        VERBOSE = 0

    if args.debug:
        DEBUG = 1

    if args.init:
        init_config_interactive()
        return 0

    base_profile = args.profile or "config"

    if not base_profile.isidentifier():
        print(f"ERROR: Invalid profile name '{base_profile}'.", file=sys.stderr)
        return 1

    if args.list_profiles:
        ensure_config_exists()
        profiles = sorted(p.stem for p in APP_DIR.glob("*.json"))
        for name in profiles:
            print(name)
        return 0

    if args.init_profile:
        new_name = args.init_profile
        if not new_name.isidentifier():
            print(f"ERROR: Invalid profile name '{new_name}'.", file=sys.stderr)
            return 1
        CONFIG_FILE = get_profile_path(new_name)
        init_config_interactive()
        return 0

    if args.copy_profile:
        new_name = args.copy_profile
        if new_name == "config":
            print("ERROR: Cannot copy to profile name 'config'.", file=sys.stderr)
            return 1
        if not new_name.isidentifier():
            print(f"ERROR: Invalid profile name '{new_name}'.", file=sys.stderr)
            return 1
        src_path = get_profile_path(base_profile)
        dst_path = get_profile_path(new_name)
        if not src_path.exists():
            print(f"ERROR: Source profile '{base_profile}' does not exist.", file=sys.stderr)
            return 1
        if dst_path.exists():
            print(f"ERROR: Destination profile '{new_name}' already exists.", file=sys.stderr)
            return 1
        try:
            dst_path.write_text(src_path.read_text(encoding="utf-8"), encoding="utf-8")
        except Exception as exc:
            print(f"ERROR: Failed to copy profile: {exc}", file=sys.stderr)
            return 1
        print(f"Profile '{base_profile}' copied to '{new_name}'.")
        return 0

    if args.remove_profile:
        name = args.remove_profile
        if name == "config":
            print("ERROR: Cannot remove the default 'config' profile.", file=sys.stderr)
            return 1
        if not name.isidentifier():
            print(f"ERROR: Invalid profile name '{name}'.", file=sys.stderr)
            return 1
        path = get_profile_path(name)
        if not path.exists():
            print(f"ERROR: Profile '{name}' does not exist.", file=sys.stderr)
            return 1
        try:
            path.unlink()
        except Exception as exc:
            print(f"ERROR: Failed to remove profile: {exc}", file=sys.stderr)
            return 1
        print(f"Profile '{name}' removed.")
        return 0

    CONFIG_FILE = get_profile_path(base_profile)

    if args.print_default_config:
        print(json.dumps(DEFAULT_CONFIG, indent=2, ensure_ascii=False))
        return 0

    if args.print_current_config:
        ensure_config_exists()
        try:
            print(CONFIG_FILE.read_text(encoding="utf-8"))
        except Exception as exc:
            print(f"ERROR: Unable to read config file: {exc}", file=sys.stderr)
            return 1
        return 0


    ask_mode: bool = args.ask is not None or args.ask_file is not None
    file_names: list[str] = []

    if not ask_mode and not args.list_models:
        if args.task:
            task = read_prompt_argument(args.task)
        elif args.task_file:
            task = read_file(args.task_file).strip()
        else:
            print("ERROR: --ask or --task required (--help for help)", file=sys.stderr)
            return 1

        if args.files_list:
            try:
                file_names = read_files_list(args.files_list)
            except ValueError as exc:
                print(f"ERROR: {exc}", file=sys.stderr)
                return 1
        elif args.files:
            file_names = args.files

        if not file_names:
            print("ERROR: --files or --files-list required (--help for help)", file=sys.stderr)
            return 1
    else:
        task = ""

    config = load_config()

    add_line_numbers = (
        args.no_line_numbers
        if args.no_line_numbers is not None
        else coerce_bool(config.get("line_numbers", "on"), True)
    )

    quiet_enabled = (
        args.quiet
        if args.quiet is not None
        else coerce_bool(config.get("quiet", "off"))
    )
    if quiet_enabled:
        VERBOSE = 0

    patch_mode = args.patch or coerce_bool(config.get("patch", "off"))
    patch_review = args.patch_review or coerce_bool(config.get("patch_review", "off"))

    configured_patch_suffix = str(config.get("patch_suffix", DEFAULT_CONFIG["patch_suffix"]) or "").strip()
    if args.patch_suffix is not None:
        patch_suffix = args.patch_suffix
        suffix_provided = True
    elif configured_patch_suffix and configured_patch_suffix.lower() != "off":
        patch_suffix = configured_patch_suffix
        suffix_provided = configured_patch_suffix != DEFAULT_CONFIG["patch_suffix"]
    else:
        patch_suffix = DEFAULT_CONFIG["patch_suffix"]
        suffix_provided = False

    if patch_mode and not args.task:
        print("ERROR: --patch requires --task", file=sys.stderr)
        return 1
    if patch_mode and (args.ask or args.ask_file or args.task_file):
        print("ERROR: --patch only supports --task (not --ask/--ask-file)", file=sys.stderr)
        return 1

    llm_timeout = (
        args.llm_timeout
        if args.llm_timeout is not None
        else config.get("llm_timeout", 300)
    )

    model = str(args.model or config.get("model")).strip()
    openai_base_url = str(args.openai_base_url or config.get("openai_base_url")).strip()
    openai_proxy = str(args.openai_proxy or config.get("openai_proxy", "")).strip()
    openai_organization = str(args.openai_organization or config.get("openai_organization", "")).strip()
    openai_project = str(args.openai_project or config.get("openai_project", "")).strip()
    safety_identifier = config.get("safety_identifier", None)
    api_log = (
        args.no_api_log
        if args.no_api_log is not None
        else coerce_bool(config.get("api_log", True), True)
    )

    if args.list_models:
        api_key = resolve_api_key(config)
        client = OpenAI(
            api_key=api_key,
            base_url=openai_base_url,
        )
        try:
            models = client.models.list()
            modelnames = []
            for m in models:
                modelnames.append(m.id)
            modelnames.sort()
            for m in modelnames:
                print(m)
        except Exception as exc:
            _handle_openai_error(exc)
        return 0

    if args.system_prompt:
        system_prompt = str(args.system_prompt).strip()
    elif args.system_prompt_file:
        system_prompt = read_file(args.system_prompt_file).strip()
    else:
        configured_system_prompt = str(config.get("system_prompt", DEFAULT_SYSTEM_PROMPT)).strip()
        system_prompt = "" if configured_system_prompt == "-" else configured_system_prompt

    if args.linenum_system_prompt:
        linenum_system_prompt = str(args.linenum_system_prompt).strip()
    else:
        linenum_system_prompt = str(
            config.get("linenum_system_prompt", DEFAULT_LINENUM_SYSTEM_PROMPT)
        ).strip()

    if args.patch_system_prompt:
        patch_system_prompt = str(args.patch_system_prompt).strip()
    else:
        patch_system_prompt = str(
            config.get("patch_system_prompt", DEFAULT_PATCH_SYSTEM_PROMPT)
        ).strip()

    temperature = (
        args.temperature
        if args.temperature is not None
        else config.get("temperature", "off")
    )
    if isinstance(temperature, str):
        if temperature.lower() == "off":
            temperature = None
        else:
            try:
                temperature = float(temperature)
            except ValueError:
                print("ERROR: Invalid temperature value.", file=sys.stderr)
                return 1

    top_p_raw = args.top_p if args.top_p is not None else config.get("top_p", "off")
    if isinstance(top_p_raw, str):
        if top_p_raw.lower() == "off":
            top_p = None
        else:
            try:
                top_p = float(top_p_raw)
            except ValueError:
                print("ERROR: Invalid top-p value.", file=sys.stderr)
                return 1
    else:
        top_p = top_p_raw

    token_limit = (
        args.token_limit
        if args.token_limit is not None
        else config.get("token_limit", 65534)
    )

    max_output_tokens = (
        args.max_output_tokens
        if args.max_output_tokens is not None
        else config.get("max_output_tokens", 65534)
    )

    openai_reasoning = (
        args.openai_reasoning
        if args.openai_reasoning is not None
        else config.get("openai_reasoning", "medium")
    )
    reasoning_mode = (
        args.reasoning_mode
        if args.reasoning_mode is not None
        else config.get("reasoning_mode", "standard")
    )
    reasoning_mode = str(reasoning_mode).strip().lower()
    if reasoning_mode not in ("standard", "pro"):
        print("ERROR: Invalid reasoning mode; choose 'standard' or 'pro'.", file=sys.stderr)
        return 1

    extra_body_raw = (
        args.openai_extra_body
        if args.openai_extra_body is not None
        else config.get("openai_extra_body")
    )
    if isinstance(extra_body_raw, dict):
        extra_body = extra_body_raw
    else:
        extra_body = parse_extra_body(str(extra_body_raw or ""))

    openai_service_tier = str(args.openai_service_tier or config.get("openai_service_tier", "off")).strip()
    response_format: str = args.response_format or str(config.get("response_format", "text"))
    token_cost_raw = (
        args.token_cost
        if args.token_cost is not None
        else config.get("token_cost", "off")
    )
    try:
        token_cost = parse_token_cost(token_cost_raw)
    except ValueError as exc:
        print(f"ERROR: Invalid token cost: {exc}", file=sys.stderr)
        return 1

    response_verbosity: str = (
        args.response_verbosity
        if args.response_verbosity is not None
        else config.get("response_verbosity", "off")
    ).lower()

    if patch_mode:
        response_format = "schema"
        json_schema = PATCH_MANIFEST_SCHEMA
        system_prompt = system_prompt + "\n" + patch_system_prompt
        add_line_numbers = True

    stream_enabled = (
        args.stream
        if args.stream is not None
        else coerce_bool(config.get("stream", "off"))
    )
    if stream_enabled and response_format != "text":
        print("ERROR: --stream is only supported for text responses", file=sys.stderr)
        return 1

    json_schema: dict[str, Any] | None = json_schema
    if response_format == "schema" and json_schema is None:
        if not args.schema_file:
            print(
                "ERROR: --schema-file is required when --response-format schema",
                file=sys.stderr,
            )
            return 1
        json_schema = load_json_schema(args.schema_file)
    elif args.schema_file and response_format != "schema":
        print(
            "ERROR: --schema-file only applies to --response-format schema",
            file=sys.stderr,
        )
        return 1

    api_key = resolve_api_key(config)
    if not api_key:
        print(f"ERROR: api_key missing in {CONFIG_FILE} or OPENAI_API_KEY", file=sys.stderr)
        print("\nRun:")
        print("  mince --init")
        return 1

    log_enabled = (
        args.log
        if args.log is not None
        else coerce_bool(config.get("log", "on"), True)
    )
    log_path = None
    if log_enabled:
        LOG_DIR = APP_DIR / "logs"
        LOG_DIR.mkdir(parents=True, exist_ok=True)
        rand_part = "".join(random.choices(string.ascii_letters + string.digits, k=8))
        timestamp = int(time.time())
        log_path = LOG_DIR / f"{base_profile}-{timestamp}-{rand_part}.txt"
        with open(log_path, "w", encoding="utf-8") as f:
            f.write(f"start_time={time.ctime(timestamp)}\n")

    if ask_mode:
        context = ""
        if args.ask is not None:
            user_prompt = read_prompt_argument(args.ask)
        else:
            user_prompt = read_file(args.ask_file).strip()
        full_system_prompt = system_prompt
    else:
        max_file_size_kb = coerce_int(config.get("max_file_size_kb", 512), 512)
        file_paths = [Path(f).resolve() for f in file_names]
        context = build_context(
            file_paths=file_paths,
            max_file_size_kb=max_file_size_kb,
            add_line_numbers=add_line_numbers
        )
        if add_line_numbers or patch_mode:
            full_system_prompt = (linenum_system_prompt + "\n" + system_prompt)
        else:
            full_system_prompt = system_prompt
        user_prompt = build_user_prompt(
            task=task,
            context=context,
            response_format=response_format,
            json_schema=json_schema,
        )
        if patch_mode:
            original_texts: dict[str, str] = {}
            for f in file_names:
                try:
                    abs_path = Path(f).resolve()
                    original_texts[str(abs_path)] = abs_path.read_text(encoding="utf-8")
                except Exception as exc:
                    print(f"ERROR: Could not read '{f}': {exc}", file=sys.stderr)
                    return 1
            if not original_texts:
                print("ERROR: No readable input files.", file=sys.stderr)
                return 1
            user_prompt = user_prompt + "\n" + patch_system_prompt

    request_tokens = estimate_request_tokens(
        model=model,
        system_prompt=full_system_prompt,
        user_prompt=user_prompt,
    )

    request_tokens += tokenizer_padding

    request_cost_estimate: str | None = None
    if token_cost is not None:
        request_cost_estimate = request_tokens * token_cost[0] / 1_000_000
    request_cost_log = (
        f" request_cost_estimate={request_cost_estimate:.4f}"
        if request_cost_estimate is not None
        else ""
    )
    if args.estimate_only:
        print(request_tokens)
        return 0

    if request_tokens > token_limit:
        print(f"ERROR: Estimated input token count ({request_tokens}) exceeds token limit ({token_limit})", file=sys.stderr)
        return 1

    request_characters = len(full_system_prompt + user_prompt)

    if log_enabled:
        with open(log_path, "a", encoding="utf-8") as f:
            f.write(
                f"request_characters={request_characters} request_tokens_estimate={request_tokens}{request_cost_log} model={model} "
                f"max_output_tokens={max_output_tokens} api_log={api_log} temperature={temperature} top_p={top_p} "
                f"safety_identifier='{safety_identifier}' service_tier={openai_service_tier} base_url='{openai_base_url}' "
                f"timeout={llm_timeout}\n"
            )
            f.write("<request>\n")
            f.write(f"<system_prompt>\n{full_system_prompt}\n</system_prompt>\n")
            f.write(f"<user_prompt>\n{user_prompt}\n</user_prompt>\n")
            f.write("</request>\n")

    if VERBOSE:
        if log_enabled:
            print(f"log_file={log_path}", file=sys.stderr)
        print(f"request_characters={request_characters} request_tokens_estimate={request_tokens}{request_cost_log} model={model}", file=sys.stderr)

    start_time = time.perf_counter()
    stream_file = None
    stream_output_emitted = False
    stream_sink = None

    try:
        if stream_enabled and not args.print_reasoning:
            if args.output_file:
                args.output_file.parent.mkdir(parents=True, exist_ok=True)
                stream_file = args.output_file.open("w", encoding="utf-8")

            def emit_stream_text(delta: str) -> None:
                if stream_file is not None:
                    stream_file.write(delta)
                    stream_file.flush()
                else:
                    sys.stdout.write(delta)
                    sys.stdout.flush()

            stream_sink = emit_stream_text

        response_obj, usage = call_openai(
            api_key=api_key,
            openai_base_url=openai_base_url,
            openai_proxy=openai_proxy,
            openai_organization=openai_organization,
            openai_project=openai_project,
            model=model,
            system_prompt=full_system_prompt,
            user_prompt=user_prompt,
            response_format=response_format,
            json_schema=json_schema,
            response_verbosity=response_verbosity,
            temperature=temperature,
            top_p=top_p,
            max_output_tokens=max_output_tokens,
            openai_service_tier=openai_service_tier,
            openai_reasoning=openai_reasoning,
            reasoning_mode=reasoning_mode,
            extra_body=extra_body,
            llm_timeout=llm_timeout,
            safety_identifier=safety_identifier,
            store=api_log,
            stream=stream_enabled,
        )
        if stream_enabled:
            result, usage, completed_response = consume_response_stream(
                response_obj, stream_sink
            )
            if completed_response is not None:
                response_obj = completed_response
            stream_output_emitted = stream_sink is not None
        else:
            result = getattr(response_obj, "output_text", "")
    except Exception as exc:
        print(f"OpenAI API error: {exc}", file=sys.stderr)
        return 1
    finally:
        if stream_file is not None:
            stream_file.close()

    elapsed = time.perf_counter() - start_time
    response_cost = response_cost_line(token_cost, usage)

    try:
        for item in getattr(response_obj, "output", []):
            if getattr(item, "type", None) == "reasoning":
                for content in getattr(item, "content", []):
                    if getattr(content, "type", None) == "reasoning_text":
                        reasoning = getattr(content, "text", "")
        if not reasoning:
            for item in getattr(response_obj, "output", []):
                if getattr(item, "type", None) == "reasoning":
                    for content in getattr(item, "summary", []):
                        if getattr(content, "type", None) == "summary_text":
                            reasoning = getattr(content, "text", "")
    except:
        reasoning = ""

    statsline = print_stats(
        request_characters=request_characters,
        request_tokens=request_tokens,
        processing_time=elapsed,
        response_text=result,
        usage=usage,
        response_cost=response_cost,
    )

    if log_enabled:
        with open(log_path, "a", encoding="utf-8") as f:
            if reasoning:
                f.write(f"<reasoning>\n{reasoning}\n</reasoning>\n")
            f.write(f"<response>\n{result}\n</response>\n")
            f.write(f"{statsline}\n")
            f.write(f"end_time={time.ctime(int(time.time()))}\n")

    if patch_mode:
        try:
            if not result or not result.strip():
                print("ERROR: LLM returned empty response for patch manifest", file=sys.stderr)
                return 1

            result = re.sub(r'^(?:<\|[^|]+\|>).+(?:<\|message\|>)', '', result).strip()
            manifest = json.loads(result)
        except json.JSONDecodeError as exc:
            print(result)
            if VERBOSE:
                print(statsline, file=sys.stderr)
            print(f"ERROR: Failed to parse patch manifest JSON: {exc}", file=sys.stderr)
            return 1

        updated_texts = apply_combined_patch_manifest(original_texts, manifest)
        diffs = []
        for fp, ut in updated_texts.items():
            ot = original_texts.get(fp, "")
            if ut != ot:
                d = generate_unified_diff(ot, ut, fp)
                if d: diffs.append(d)
        if not diffs:
            if VERBOSE:
                print("No changes.", file=sys.stderr)
                print(statsline, file=sys.stderr)
            return 0
        if VERBOSE or patch_review:
            print()
            print("\n".join(diffs))
        if patch_review:
            if input("\nApply these changes? [y/N]: ").strip().lower() not in ("y", "yes"):
                if VERBOSE:
                    print("Aborted.", file=sys.stderr)
                    print(statsline, file=sys.stderr)
                return 0
            for fp, ut in updated_texts.items():
                if ut == original_texts.get(fp, ""): continue
                tgt = append_suffix_to_path(Path(fp), patch_suffix) if suffix_provided else Path(fp)
                tgt.write_text(ut, encoding="utf-8")
                print(f"file_written={str(tgt) if suffix_provided else fp}")
        else:
            for fp, ut in updated_texts.items():
                if ut == original_texts.get(fp, ""): continue
                outp = append_suffix_to_path(Path(fp), patch_suffix)
                outp.write_text(ut, encoding="utf-8")
                print(f"file_written={outp}")

        if VERBOSE:
            print(statsline, file=sys.stderr)

        return 0

    if response_format in ("json", "schema"):
        try:
            if not result or not result.strip():
                print("ERROR: LLM returned empty response", file=sys.stderr)
                return 1

            result = re.sub(r'^(?:<\|[^|]+\|>).+(?:<\|message\|>)', '', result).strip()
            result = json.loads(result)
        except json.JSONDecodeError as exc:
            print(result)
            if VERBOSE:
                print(statsline, file=sys.stderr)
            print(f"ERROR: Failed to parse JSON: {exc}", file=sys.stderr)
            return 1
        finally:
            result = pretty_json(result)

    if args.print_reasoning:
        output_str = (
            f"<think>\n{reasoning}\n</think>\n\n"
            f"{result}"
        )
    else:
        output_str = result

    if args.output_file:
        if not stream_output_emitted:
            try:
                args.output_file.parent.mkdir(parents=True, exist_ok=True)
                args.output_file.write_text(output_str, encoding="utf-8")
            except Exception as exc:
                print(f"ERROR: Failed to write output to file {args.output_file}: {exc}", file=sys.stderr)
                print(output_str)
                if VERBOSE:
                    print(statsline, file=sys.stderr)
                return 1
    elif stream_output_emitted:
        if not result or not result.endswith("\n"):
            print()
    else:
        print(output_str)

    if VERBOSE:
        print(statsline, file=sys.stderr)

    if DEBUG:
        print("<debug_response>", file=sys.stderr)
        print(json.dumps(response_obj.model_dump(), indent=2), file=sys.stderr)
        print("</debug_response>", file=sys.stderr)

    return 0


