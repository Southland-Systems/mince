def build_user_prompt(
    task: str,
    context: str,
    response_format: str = "text",
    json_schema: dict[str, Any] | None = None,
) -> str:
    schema_block = ""

    if response_format == "schema" and json_schema is not None:
        schema_block = (
            "\n\nReturn ONLY valid JSON that matches this schema exactly:\n"
            f"{json.dumps(json_schema, indent=2, ensure_ascii=False)}"
        )

    return f"""
TASK:
{task}

CONTEXT:
{context}
{schema_block}
""".strip()


