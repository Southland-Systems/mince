def append_suffix_to_path(original_path: Path, suffix: str) -> Path:
    return original_path.with_name(original_path.name + suffix)

def generate_unified_diff(original: str, updated: str, path: str) -> str:
    original_lines = original.splitlines(keepends=True)
    updated_lines = updated.splitlines(keepends=True)

    fromfile = path if original else "/dev/null"
    tofile = path

    diff_lines = list(
        difflib.unified_diff(
            original_lines,
            updated_lines,
            fromfile=fromfile,
            tofile=tofile,
        )
    )
    if not diff_lines:
        return ""
    return "".join(diff_lines) + "\n"

def detect_line_ending(text: str) -> str:
    return "crlf" if "\r\n" in text else "lf"


def eol_for(line_ending: str) -> str:
    return "\r\n" if line_ending == "crlf" else "\n"


def normalize_line_for_write(text: str) -> str:
    if "\n" in text or "\r" in text:
        raise ValueError("content_line_array entries must be single logical lines without embedded newlines.")
    return text

def prefix_line_numbers(text: str) -> str:
    lines = text.splitlines(keepends=True)
    return "".join(f"{i} {line}" for i, line in enumerate(lines, start=1))

@dataclass(frozen=True)
class PatchRange:
    patch_id: str
    start_line: int
    end_line: int


def validate_patch_ranges(patches: list[dict[str, Any]], total_lines: int) -> list[PatchRange]:
    ranges: list[PatchRange] = []

    for patch in patches:
        patch_id = str(patch["patch_id"])
        start_line = int(patch["start_line"])
        end_line = int(patch["end_line"])

        if start_line < 1:
            raise ValueError(f"{patch_id}: start_line must be >= 1")
        if end_line < 1:
            raise ValueError(f"{patch_id}: end_line must be >= 1")
        if start_line > end_line:
            raise ValueError(f"{patch_id}: start_line cannot be greater than end_line")

        ranges.append(PatchRange(patch_id=patch_id, start_line=start_line, end_line=end_line))

    ranges_sorted = sorted(ranges, key=lambda r: (r.start_line, r.end_line, r.patch_id))
    prev = ranges_sorted[0]
    for current in ranges_sorted[1:]:
        if current.start_line <= prev.end_line:
            raise ValueError(
                f"Overlapping or nested blocks detected: "
                f"{prev.patch_id} [{prev.start_line}, {prev.end_line}] and "
                f"{current.patch_id} [{current.start_line}, {current.end_line}]"
            )
        prev = current

    return ranges

def apply_combined_patch_manifest(
    original_texts: dict[str, str],
    manifest: dict[str, Any],
) -> dict[str, str]:
    updated_texts: dict[str, str] = {}

    for file_entry in manifest.get("files", []):
        document = file_entry["document"]
        path = document["path"]
        if path not in original_texts:
            original = ""
        else:
            original = original_texts[path]

        updated = apply_file_patch_manifest(original, file_entry)
        updated_texts[path] = updated

    for path, text in original_texts.items():
        if path not in updated_texts:
            updated_texts[path] = text

    return updated_texts

def apply_file_patch_manifest(original_text: str, file_manifest: dict[str, Any]) -> str:
    if not file_manifest.get("patches"):
        return original_text

    document = file_manifest["document"]
    line_ending = document["line_ending"]
    eol = eol_for(line_ending)

    lines = original_text.splitlines(keepends=False)
    total_lines = len(lines)

    validate_patch_ranges(file_manifest["patches"], total_lines)

    # Apply patches in reverse order so earlier line numbers stay valid
    patches = sorted(
        file_manifest["patches"],
        key=lambda p: int(p["start_line"]),
        reverse=True,
    )

    for patch in patches:
        start_line = int(patch["start_line"])
        end_line = int(patch["end_line"])

        removed = lines[start_line - 1 : end_line]

        replacement = [
            normalize_line_for_write(line)
            for line in patch["content_line_array"]
        ]

# TODO debugging
#        patch_id = patch.get("patch_id", "<unknown>")
#        print(
#            f"Applying patch {patch_id}: remove lines {start_line}-{end_line}",
#            file=sys.stderr,
#        )
#        for line in removed:
#            print(f"- {line}", file=sys.stderr)
#        if replacement:
#            print(
#                f"Add {len(replacement)} line(s) at {start_line}:",
#                file=sys.stderr,
#            )
#            for line in replacement:
#                print(f"+ {line}", file=sys.stderr)
#        else:
#            print("No lines added (pure deletion).", file=sys.stderr)

        # Perform the slice replacement
        lines[start_line - 1 : end_line] = replacement

    result = eol.join(lines)
    if original_text.endswith(eol):
        result += eol
    return result


